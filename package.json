{
  "name": "web-universal-storage",
  "version": "0.2.0-next.0",
  "description": "Unified, type-safe API for localStorage, sessionStorage, cookies, and IndexedDB with SSR-safe fallbacks.",
  "license": "MIT",
  "keywords": [
    "storage",
    "universal-storage",
    "localstorage",
    "sessionstorage",
    "cookie",
    "cookies",
    "indexeddb",
    "browser",
    "encryption",
    "secure-storage",
    "webcrypto",
    "aes-gcm",
    "ssr",
    "nextjs",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huseyinekh/universal-storage.git"
  },
  "bugs": {
    "url": "https://github.com/huseyinekh/universal-storage/issues"
  },
  "homepage": "https://github.com/huseyinekh/universal-storage#readme",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "cjs.cjs",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./cjs.cjs"
    }
  },
  "main": "./cjs.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}

